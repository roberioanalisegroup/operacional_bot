# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA faça commit do .env real.

# -----------------------------------------------------------------------------
# Banco de dados (Supabase Postgres)
# -----------------------------------------------------------------------------
# Pegue em: Supabase > seu projeto > Project Settings > Database > Connection string
# Use a connection string do modo "Transaction" (porta 6543) para produção.
# Substitua [YOUR-PASSWORD] pela senha do banco.
DATABASE_URL=postgresql://postgres.xxxxxxx:[YOUR-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# -----------------------------------------------------------------------------
# Segurança
# -----------------------------------------------------------------------------
# Gere com:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=troque-por-uma-chave-longa-e-aleatoria
SECRET_KEY=troque-por-outra-chave-longa-e-aleatoria

# Duração do token JWT, em horas
JWT_EXPIRES_HOURS=8

# -----------------------------------------------------------------------------
# Administrador criado automaticamente se NENHUM admin existir no banco
# -----------------------------------------------------------------------------
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=admin@2026
ADMIN_BOOTSTRAP_DISPLAY_NAME=Administrador

# -----------------------------------------------------------------------------
# Flask
# -----------------------------------------------------------------------------
FLASK_DEBUG=0
AUTO_MIGRATE=1
